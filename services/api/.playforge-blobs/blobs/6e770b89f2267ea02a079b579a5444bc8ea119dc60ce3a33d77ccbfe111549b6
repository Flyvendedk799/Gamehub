<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Red Square Bounce Game</title>
  <style>
    body { margin: 0; }
  </style>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/phaser/3.60.0/phaser.min.js"></script>
</head>
<body>
  <script>
    window.onload = function() {
      const config = {
        type: Phaser.AUTO,
        width: 800,
        height: 600,
        physics: {
          default: 'arcade',
          arcade: {
            gravity: { y: 0 },
            debug: false
          }
        },
        scene: MainScene
      };

      new Phaser.Game(config);
    };

    class MainScene extends Phaser.Scene {
      constructor() {
        super({ key: 'MainScene' });
      }

      preload() {
        this.load.audio('bounce', 'assets/audio/bounce.wav');
      }

      create() {
        // Create red square texture
        this.add.graphics()
          .fillStyle(0xff0000, 1)
          .fillRect(0, 0, 64, 64)
          .generateTexture('redSquare', 64, 64)
          .destroy();

        // Add sprite
        this.square = this.physics.add.sprite(400, 300, 'redSquare');
        this.square.setVelocity(200, 200);
        this.square.setBounce(1, 1);
        this.square.setCollideWorldBounds(true);
        this.square.body.onWorldBounds = true;

        // Bounce counter
        this.score = 0;
        this.bounceText = this.add.text(16, 16, 'Score: 0', { font: '24px Arial', fill: '#ffffff' });
        window.__game = {};
        Object.defineProperty(window.__game, 'debug', { get: () => ({ score: this.score }) });

        // World bounds event
        this.physics.world.on('worldbounds', (body) => {
          if (body.gameObject === this.square) {
            this.bounceCount++;
            this.score++;
            this.bounceText.setText('Score: ' + this.score);
            if (this.bounceCount >= 10 && !this.gameOver) {
            if (this.score >= 10 && !this.gameOver) {
            }
          }
        });

        // Timer for lose condition
        this.time.delayedCall(30000, () => {
          if (!this.gameOver) {
            this.loseGame();
          }
        });

        // Restart key
        this.input.keyboard.on('keydown-R', () => {
          this.scene.restart();
        });
      }

      winGame() {
        this.gameOver = true;
        this.physics.pause();
        this.add.text(400, 300, 'You Win! Press R to restart', { font: '32px Arial', fill: '#00ff00' }).setOrigin(0.5);
      }

      loseGame() {
        this.gameOver = true;
        this.physics.pause();
        this.add.text(400, 300, 'Game Over! Press R to restart', { font: '32px Arial', fill: '#ff0000' }).setOrigin(0.5);
      }
    }
  </script>
</body>
</html>