{
  "name": "playforge",
  "version": "0.0.0",
  "private": true,
  "description": "Cloud-native AI game builder — describe a game in natural language, get a real playable web game, publish and remix in a community hub. (Working codename: Playforge.)",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "eval:games": "pnpm --filter @playforge/agent-core eval:games",
    "analyze:runs": "pnpm --filter @playforge/agent-core analyze:runs",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "bullmq": "^5.78.1",
    "ioredis": "^5.11.1"
  }
}
